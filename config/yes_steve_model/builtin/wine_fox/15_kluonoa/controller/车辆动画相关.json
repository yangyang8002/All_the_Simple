{
	"format_version": "1.19.0",
	"animation_controllers": {
		"player.post_main_car_hood": {
			"states": {
				"default": {
					"transitions": [
						{"hood_open": "v.roaming.car_hood != v.roaming.car_hood_state && v.roaming.car_hood_state == 0"},
						{"hood_close": "v.roaming.car_hood != v.roaming.car_hood_state && v.roaming.car_hood_state == 1"}
					]
				},
				"hood_open": {
					"animations": [
						{"开前备箱": "v.show_car"}
					],
					"on_entry": ["v.roaming.car_hood_state = v.roaming.car_hood;"],
					"transitions": [
						{"default": "q.all_animations_finished"}
					]
				},
				"hood_close": {
					"animations": [
						{"关前备箱": "v.show_car"}
					],
					"on_entry": ["v.roaming.car_hood_state = v.roaming.car_hood;"],
					"transitions": [
						{"default": "q.all_animations_finished"}
					]
				}
			}
		},
		"player.post_main_car_trunk": {
			"states": {
				"default": {
					"transitions": [
						{"trunk_open": "v.roaming.car_trunk != v.roaming.car_trunk_state && v.roaming.car_trunk_state == 0"},
						{"trunk_close": "v.roaming.car_trunk != v.roaming.car_trunk_state && v.roaming.car_trunk_state == 1"}
					]
				},
				"trunk_open": {
					"animations": [
						{"开后备箱": "v.show_car"}
					],
					"on_entry": ["v.roaming.car_trunk_state = v.roaming.car_trunk;"],
					"transitions": [
						{"default": "q.all_animations_finished"}
					]
				},
				"trunk_close": {
					"animations": [
						{"关后备箱": "v.show_car"}
					],
					"on_entry": ["v.roaming.car_trunk_state = v.roaming.car_trunk;"],
					"transitions": [
						{"default": "q.all_animations_finished"}
					]
				}
			}
		},
		"player.post_main_car_left_door": {
			"states": {
				"default": {
					"transitions": [
						{"trunk_open": "v.roaming.car_left_door != v.roaming.car_left_door_state && v.roaming.car_left_door_state == 0"},
						{"trunk_close": "v.roaming.car_left_door != v.roaming.car_left_door_state && v.roaming.car_left_door_state == 1"}
					]
				},
				"trunk_open": {
					"animations": [
						{"开左车门": "v.show_car"}
					],
					"on_entry": ["v.roaming.car_left_door_state = v.roaming.car_left_door;"],
					"transitions": [
						{"default": "q.all_animations_finished"}
					]
				},
				"trunk_close": {
					"animations": [
						{"关左车门": "v.show_car"}
					],
					"on_entry": ["v.roaming.car_left_door_state = v.roaming.car_left_door;"],
					"transitions": [
						{"default": "q.all_animations_finished"}
					]
				}
			}
		},
		"player.post_main_car_right_door": {
			"states": {
				"default": {
					"transitions": [
						{"trunk_open": "v.roaming.car_right_door != v.roaming.car_right_door_state && v.roaming.car_right_door_state == 0"},
						{"trunk_close": "v.roaming.car_right_door != v.roaming.car_right_door_state && v.roaming.car_right_door_state == 1"}
					]
				},
				"trunk_open": {
					"animations": [
						{"开右车门": "v.show_car"}
					],
					"on_entry": ["v.roaming.car_right_door_state = v.roaming.car_right_door;"],
					"transitions": [
						{"default": "q.all_animations_finished"}
					]
				},
				"trunk_close": {
					"animations": [
						{"关右车门": "v.show_car"}
					],
					"on_entry": ["v.roaming.car_right_door_state = v.roaming.car_right_door;"],
					"transitions": [
						{"default": "q.all_animations_finished"}
					]
				}
			}
		}
	}
}